body {
  font-family: Arial;
  padding: 40px;
  background: #f4f4f4;
}

h1 {
  margin-bottom: 20px;
}

textarea {
  width: 400px;
  height: 120px;
  margin-top: 10px;
}

input {
  margin-top: 10px;
}

button {
  margin-top: 20px;
  padding: 10px 20px;
  background: gold;
  border: none;
  cursor: pointer;
}

pre {
  background: white;
  padding: 15px;
  margin-top: 20px;
  border-radius: 8px;
}
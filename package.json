import express from 'express'
import path from 'path'
import { fileURLToPath } from 'url'

const __filename = fileURLToPath(import.meta.url)
const __dirname = path.dirname(__filename)

const app = express()

// 🔐 LOGIN (JETZT ESM-KORREKT)
app.use((req, res, next) => {
if (req.path === '/health') return next()

const user = process.env.JURICO_USER || "admin"
const pass = process.env.JURICO_PASSWORD || "1234"

const auth = req.headers.authorization

if (!auth) {
res.set('WWW-Authenticate', 'Basic realm="Login Required"')
return res.status(401).send('Login required')
}

const b64 = auth.split(' ')[1]
const [login, password] = Buffer.from(b64, 'base64').toString().split(':')

if (login === user && password === pass) {
return next()
}

res.set('WWW-Authenticate', 'Basic realm="Login Required"')
return res.status(401).send('Login required')
})

// Middleware
app.use(express.json())
app.use(express.urlencoded({ extended: true }))

// Static
app.use(express.static(path.join(__dirname, 'public')))

// Health
app.get('/health', (req, res) => {
res.json({ status: "ok" })
})

// Startseite
app.get('/', (req, res) => {
res.sendFile(path.join(__dirname, 'public', 'index.html'))
})

const PORT = process.env.PORT || 10000

app.listen(PORT, () => {
console.log(`JURICO läuft auf Port ${PORT}`)
})
